{
  "$schema": "./qcopilots_service.schema.json",
  "service_id": "qcopilots.mcp_server_interactive_tools",
  "plugin_name": "QCopilots MCP Server Interactive Tools",
  "display_name": "QCopilots MCP Server Interactive Tools",
  "description": "通过 QGIS bridge 将常用桌面交互动作和图层操作暴露为 MCP 工具，覆盖图层枚举、XYZ/WMS/WCS/provider 图层加载、移除、可见性切换、缩放、地图画布、工程状态、数据导出、矢量数据创建和要素更新等操作。适合让 llama-ui 或其它 MCP 客户端在已运行的 QGIS 会话中执行可见的地图自动化任务，服务依赖 QGIS bridge、当前桌面工程状态和本机数据访问权限。",
  "entry_point": "server.py",
  "host": "127.0.0.1",
  "default_port": 48213,
  "mcp_path": "/mcp",
  "category": "qcopilots",
  "capabilities": ["tools", "qgis-bridge"],
  "runtime": {
    "type": "uv",
    "requirements": "requirements.lock"
  },
  "cors_origins": ["http://127.0.0.1:8282", "http://localhost:8282"]
}
