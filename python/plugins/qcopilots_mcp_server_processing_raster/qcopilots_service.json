{
  "$schema": "./qcopilots_service.schema.json",
  "service_id": "qcopilots.mcp_server_processing_raster",
  "plugin_name": "QCopilots MCP Server Processing Raster",
  "display_name": "QCopilots MCP Server Processing Raster",
  "description": "通过 QGIS bridge 将 QGIS Processing 中的栅格算法暴露为 MCP 工具，覆盖 DEM、栅格计算、重采样、格式转换和栅格分析等处理流程。适合让 llama-ui 或其它 MCP 客户端驱动 QGIS 完成栅格数据处理任务，服务依赖当前 QGIS Processing 环境、可用 provider 和本机数据访问权限。",
  "entry_point": "server.py",
  "host": "127.0.0.1",
  "default_port": 48215,
  "mcp_path": "/mcp",
  "category": "qcopilots",
  "capabilities": ["tools", "processing", "raster"],
  "runtime": {
    "type": "uv",
    "requirements": "requirements.lock"
  },
  "cors_origins": ["http://127.0.0.1:8282", "http://localhost:8282"]
}
